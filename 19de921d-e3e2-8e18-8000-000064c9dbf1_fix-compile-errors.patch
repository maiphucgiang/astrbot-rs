+#[async_trait]
+impl EmbeddingProvider for MockProvider {
+    fn id(&self) -> &str {
+        &self.id
+    }
+
+    fn name(&self) -> &str {
+        &self.name
+    }
+
+    async fn embed(&self, text: &str) -> Result<Vec<f32>> {
+        let results = self.batch_embed(vec![text.to_string()]).await?;
+        results.into_iter().next().ok_or_else(|| crate::errors::AstrBotError::Internal("Empty embedding".to_string()))
+    }
+
+    async fn batch_embed(&self, texts: Vec<String>) -> Result<Vec<Vec<f32>>> {
+        if !self.embeddings.is_empty() {
+            return Ok(self.embeddings.clone());
+        }
+        Ok(texts.iter().map(|t| self.generate_embedding(t)).collect())
+    }
+
+    async fn health_check(&self) -> Result<()> {
+        if self.should_fail_health {
+            Err(crate::errors::AstrBotError::Provider {
+                provider: self.name.clone(),
+                message: "Mock health failure".to_string(),
+            })
+        } else {
+            Ok(())
+        }
+    }
+}
